datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

model User {
    id    String    @id @default(uuid(7))
    email String @unique
    password_hash String 
    name String
    createdAt DateTime @default(now()) @db.Timestamptz

    @@index([email], name: "idx_email")

    polls Poll[]
    responses Response[]
}

model Poll {
    id String @id @default(uuid(7))
    short_id String @unique @db.VarChar(12)
    creator_id String
    title String @db.VarChar(200)
    description String? @db.VarChar(1000)
    response_mode PollResponseMode
    state PollState @default(ACTIVE)
    expires_at DateTime @db.Timestamptz()
    published_at DateTime? @db.Timestamptz()
    created_at DateTime @default(now()) @db.Timestamptz

    

    @@index([short_id], name: "idx_short_id")
    @@index([creator_id], name: "idx_creator_id")
    @@index([state, expires_at(sort: Desc)], name: "idx_state_expires_at")

    creator User @relation(fields: [creator_id], references: [id], onDelete: Cascade)
    questions Question[]
    responses Response[]
}

model Question {
    id String @id @default(uuid(7))
    poll_id String
    text String @db.VarChar(500)
    is_mandatory Boolean @default(false)
    order_index Int

    poll Poll @relation(fields: [poll_id], references: [id])

    @@unique([poll_id, order_index], name: "idx_poll_id_order_index_unique")
    option Option[]
    answer Answer[]
}

model Option {
    id String @id @default(uuid(7))
    question_id String
    text String @db.VarChar(200)
    order_index Int

    @@unique([question_id, order_index], name: "idx_question_id_order_index_unique")
    // relation
    // question, cascade delete
    question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)

    answer Answer[]
}

model Response {
    id String @id @default(uuid(7)) 
    poll_id String
    respondent_id String?
    submitted_at DateTime @default(now()) @db.Timestamptz()

    @@index([poll_id], name: "idx_poll_id")
    // todo unique partial index of poll_id and repondent_id via migration 

    
    // relation
    // Poll id
    poll Poll @relation(fields: [poll_id], references: [id], onDelete: Cascade)
    // user id , null = anonymous
    respondent User? @relation(fields: [respondent_id], references: [id])

    answers Answer[]
}

model Answer {
    id String @id @default(uuid(7))
    response_id String
    question_id String
    selected_option_id String?

    @@index([response_id], name: "idx_response_id")
    @@index([question_id], name: "idx_question_id")
    @@index([selected_option_id], name: "idx_selected_option_id")

    // relation
    // response, cascade delete
    response Response @relation(fields: [response_id], references: [id], onDelete: Cascade)
    // question
    question Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
    // option
    option Option? @relation(fields: [selected_option_id], references: [id], onDelete: Cascade)
}

enum PollResponseMode {
    ANONYMOUS
    AUTHENTICATED
}

enum PollState {
    ACTIVE
    EXPIRED
    PUBLISHED
}
